{
  "devDependencies": {
    "prettier": "3.8.4",
    "renovate": "43.204.1"
  },
  "packageManager": "yarn@4.17.1",
  "scripts": {
    "format": "prettier --log-level warn --no-error-on-unmatched-pattern --write '**/*.yml' '**/*.json' '**/*.md'",
    "check-format": "prettier --no-error-on-unmatched-pattern --check '**/*.yml' '**/*.json' '**/*.md'"
  },
  "dependenciesMeta": {
    "prettier@3.8.4": {
      "unplugged": true
    }
  }
}
