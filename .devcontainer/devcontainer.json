{
  "name": "config",
  "build": {
    "cacheFrom": "ghcr.io/marinatedconcrete/config-devcontainer",
    "context": "..",
    "dockerfile": "Containerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        // Enable VSCode to find the prettier package to use when formatting
        "arcanis.vscode-zipfs",
        "github.vscode-github-actions",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "nefrob.vscode-just-syntax",
        "redhat.vscode-yaml"
      ],
      "files.readonlyInclude": {
        "kustomization/components/kube-vip/daemonset/services.yml": true,
        "kustomization/components/kube-vip/daemonset/vip.yml": true,
        "kustomization/components/kube-vip/rbac.yml": true
      },
      "settings": {
        "prettier.useEditorConfig": false,
        "search.exclude": {
          "**/.yarn": true,
          "**/.pnp.*": true
        },
        "prettier.prettierPath": ".yarn/sdks/prettier/index.js"
      }
    }
  },
  "containerEnv": {
    "DOCKER_BUILDKIT": "1"
  },
  "features": {
    "ghcr.io/devcontainers/features/node:2": {
      "installYarnUsingApt": "false",
      // Save on space since we don't need this
      "nodeGypDependencies": "false",
      // renovate: datasource=github-releases depName=nvm-sh/nvm
      "nvmVersion": "0.40.5",
      "pnpmVersion": "none",
      // renovate: datasource=node-version depName=node
      "version": "24.18.0"
    }
  },
  "mounts": [
    {
      "source": "dind-var-lib-docker-${devcontainerId}",
      "target": "/var/lib/docker",
      "type": "volume"
    },
    {
      "source": "dind-var-lib-containerd-${devcontainerId}",
      "target": "/var/lib/containerd",
      "type": "volume"
    }
  ],
  "postCreateCommand": ".devcontainer/post-create-command.sh",
  "postStartCommand": "sudo /usr/local/share/docker-init.sh",
  "privileged": true,
  "containerUser": "vscode",
  "remoteUser": "vscode"
}
